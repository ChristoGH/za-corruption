# Environment
.env
.env.*
!.env.example
!.env.test

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Node
node_modules/
.npm/

# Build artifacts
/build
.output
/.svelte-kit

# OS
.DS_Store
Thumbs.db
Desktop.ini
._*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Claude / Cursor agent worktrees
.claude/

# BMad personal-scope config (per-user; never commit)
_bmad/config.user.toml
_bmad/**/*.user.toml

# Vitest temp config files
vitest.config.*.timestamp-*.mjs

# Google Cloud credentials
*.json
!package.json
!tsconfig.json
!**/fixtures/**/*.json
# apps/web build config + lockfile (the blanket *.json above would hide them)
!apps/web/tsconfig.node.json
!apps/web/package-lock.json

# Logs
*.log
npm-debug.log*

# Coverage
coverage/
.coverage
htmlcov/

# Secrets / test artifacts
test-secret.txt

# Downloaded commission PDFs (keep directory structure via .gitkeep)
/data/raw/**
!/data/raw/
!/data/raw/*/
!**/.gitkeep

# Parsed chunk output — derived, regenerable from data/raw via parse-corpus
/data/processed/**
!/data/processed/
!/data/processed/*/

# Source-check reports — regenerable run artifacts
/reports/

# Playwright session secrets (manual Zondo harvest)
playwright-storage-state.json

# Extraction cache — LLM outputs keyed (chunk_id, prompt_version, model).
# Regenerable but paid: back it up before deleting. Not committed (derived
# content about named individuals stays out of the repo).
/data/cache/**
!/data/cache/

# Neo4j graph dumps (make backup) — large binaries containing derived content
# about named individuals; keep out of the repo, store/back up separately.
/backups/
*.dump

# Screen recordings / rendered video (hundreds of MB). Delivery artifacts, not
# source; share via the outputs folder, never commit to git.
/video-delivery/
*.mp4
