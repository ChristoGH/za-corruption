# Retrieval politeness (optional overrides)
# INGEST_USER_AGENT=transcript-research-bot/0.1 contact: you@example.com
# INGEST_REQUEST_DELAY_SECONDS=0.75

# Zondo official site manual session (short-lived; keep outside the repo)
# INGEST_ZONDO_CF_COOKIE=
# INGEST_ZONDO_STORAGE_STATE=/path/to/playwright-storage-state.json

# GitHub API token for DSFSI bootstrap listing (optional; raises rate limit)
# GITHUB_TOKEN=

# Store URLs (M2+) — defaults match docker-compose.yml
# QDRANT_URL=http://localhost:6333
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=changeme
